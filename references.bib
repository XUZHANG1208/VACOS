
@article{szmrecsanyi_toward_2016,
	title = {Toward more accountability: {Modeling} ternary genitive variation in {Late} {Modern} {English}},
	volume = {28},
	copyright = {https://www.cambridge.org/core/terms},
	issn = {0954-3945, 1469-8021},
	shorttitle = {Toward more accountability},
	url = {https://www.cambridge.org/core/product/identifier/S0954394515000198/type/journal_article},
