@article{gardner_be_2021,
	title = {\textit{{Be} like} and the {Constant} {Rate} {Effect}: from the bottom to the top of the \textit{{S}} -curve},
	volume = {25},
	issn = {1360-6743, 1469-4379},
	shorttitle = {\textit{{Be} like} and the {Constant} {Rate} {Effect}},
	url = {https://www.cambridge.org/core/product/identifier/S1360674320000076/type/journal_article},
	doi = {10.1017/S1360674320000076},
	abstract = {The
              be like
              quotative emerged rapidly around the English-speaking world and has quickly saturated the quotative systems of young speakers in multiple countries. We study
              be like
              (and its covariants) in two communities – Toronto, Canada, and York, United Kingdom – in apparent time and at two separate points in real time. We trace the apparent-time trajectory of
              be like
              and its covariants from inception to saturation. We take advantage of the prodigious size of our dataset to examine understudied aspects of the linguistic factors that condition quotative variation. Building on earlier suggestions (Cukor-Avila 2002; Durham
              et al.
              2012) that
              be like
              might show patterning over time consistent with the C
              onstant
              R
              ate
              E
              ffect
              (or CRE, Kroch 1989), we argue that the CRE does indeed apply to the rise of
              be like
              , but needs to be handled with care. Logistic modelling assumes that the top of the
              S
              -curve is located at 100 per cent of a given variable context. In the case of
              be like
              , the saturation point is nearer 75–85 per cent, with minor variants retaining small semantic footholds in the system. In conjunction with our analysis, we suggest how to adapt the predictions of the CRE to changes likely to lead to saturation but not categorical use.},
	language = {en},
	number = {2},
	urldate = {2026-01-29},
	journal = {English Language and Linguistics},
	author = {Gardner, Matt Hunt and Denis, Derek and Brook, Marisa and Tagliamonte, Sali A.},
	month = jun,
	year = {2021},
	pages = {281--324},
}

